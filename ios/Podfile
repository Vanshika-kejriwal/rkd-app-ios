# Set the global deployment target matching your project configuration
platform :ios, '13.0'

# Securely locate and evaluate the Flutter dependency helper script
flutter_install_from_path = File.join(File.dirname(__file__), 'Flutter', 'podhelper.rb')
require flutter_install_from_path

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # This is the correct Flutter helper method that dynamically links your plugins
  flutter_install_all_ios_pods File.dirname(__file__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      # Force deployment uniformity across all packages
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end